{
    "name": "abu-asim-management-system",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "electron": "electron .",
        "build": "vite build",
        "build-app": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false vite build && electron-builder",
        "lint": "eslint .",
        "preview": "vite preview"
    },
    "dependencies": {
        "firebase": "^12.12.1",
        "html-to-image": "^1.11.13",
        "lucide-react": "^1.14.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.2",
        "recharts": "^3.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "better-sqlite3": "^12.10.0",
        "cross-env": "^10.1.0",
        "electron": "^42.0.1",
        "electron-builder": "^26.8.1",
        "electron-is-dev": "^3.0.1",
        "electron-rebuild": "^3.2.9",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "vite": "^8.0.10",
        "vite-plugin-pwa": "^1.3.0"
    },
    "build": {
        "appId": "com.abuasim.management",
        "productName": "Abu Asim System",
        "directories": {
            "output": "release"
        },
        "win": {
            "icon": "public/logo.png",
            "target": [
                "nsis",
                "portable"
            ]
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "public/logo.png",
                "to": "logo.png"
            }
        ]
    }
}
